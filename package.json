{
  "name": "spaghetti-slicer",
  "version": "0.1.0",
  "description": "Frontend best practices auditor for React/TypeScript codebases",
  "bin": { "spaghetti-slicer": "./dist/index.js" },
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "build": "tsup src/cli/index.ts --format cjs --dts --clean",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@typescript-eslint/parser": "^7.0.0",
    "@typescript-eslint/utils": "^7.0.0",
    "ts-morph": "^21.0.0",
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.0",
    "cli-table3": "^0.6.3",
    "boxen": "^8.0.0",
    "glob": "^11.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "vitest": "^1.6.0",
    "@types/node": "^20.0.0"
  }
}
